{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SB712: targeted security tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/test_security.py",
        "-q"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "SB712: service host heartbeat",
      "type": "debugpy",
      "request": "launch",
      "module": "sb_712.service_host",
      "args": [
        "--heartbeat-once"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    }
  ]
}
